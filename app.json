{
  "expo": {
    "name": "MONSAM",
    "slug": "monsam-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#155124"
    },
    "ios": { "supportsTablet": false },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#155124"
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#155124"
      },
      "usesCleartextTraffic": true,
      "permissions": ["android.permission.INTERNET", "android.permission.ACCESS_NETWORK_STATE", "android.permission.CAMERA"],
      "package": "com.e500.monsammobile"
    },
    "scheme": "monsam",
    "plugins": ["./plugins/withCleartextTraffic"],
    "extra": {
      "eas": {
        "projectId": "83ca23a8-2ae6-45d5-b96e-2feb7591d964"
      }
    }
  }
}
